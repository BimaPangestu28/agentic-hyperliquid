TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789
HYPERLIQUID_AGENT_KEY=
# Master account address (0x...) that holds your funds. REQUIRED when HYPERLIQUID_AGENT_KEY
# is an API/agent wallet (agent wallets hold no balance). If unset, the bot queries the
# agent key's own address and equity will read 0.
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_NETWORK=testnet
# Set to true if your Hyperliquid account uses UNIFIED ACCOUNT mode (spot+perp collateral unified).
# When true, the bot reads equity from your spot USDC balance instead of the perp account.
HYPERLIQUID_UNIFIED_ACCOUNT=true
RISK_PCT=1.0
LEVERAGE_CONSERVATIVE=2
LEVERAGE_MODERATE=3
LEVERAGE_AGGRESSIVE=5
ENTRY_FILL_TIMEOUT_SECS=300
# CONFIDENCE_GATE=6

# DeepSeek LLM card parser (optional; falls back to regex if unset)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Max cumulative risk to commit per UTC day, as % of equity (each trade risks RISK_PCT).
# Confirmed trades that would exceed this are skipped. Leave empty to disable.
MAX_DAILY_RISK_PCT=5.0

# OpenAI vision for reading signal SCREENSHOTS (DeepSeek's API can't accept images).
# Leave OPENAI_API_KEY empty to disable image parsing (text paste still works).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
