BOT_API_URL=http://localhost:8080
BOT_API_TOKEN=changeme
HYPERLIQUID_URL=https://app.hyperliquid.xyz
NEUROBRO_URL=https://app.neurobro.ai
NEUROBRO_STORAGE_STATE=./neurobro-session.json
POLL_INTERVAL_SECS=60
COOLDOWN_SECS=300
MAX_DEVIATION=0.004
# Persistent Chrome profile dir (Cloudflare cf_clearance + Neurobro auth live here)
NEUROBRO_USER_DATA_DIR=./neurobro-profile
# Run headful by default (Cloudflare flags headless). Set true only under xvfb.
HEADLESS=false
# Use real installed Chrome instead of Playwright's bundled Chromium
BROWSER_CHANNEL=chrome
