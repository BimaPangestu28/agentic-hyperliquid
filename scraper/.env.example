BOT_API_URL=http://localhost:8080
BOT_API_TOKEN=changeme
HYPERLIQUID_URL=https://app.hyperliquid.xyz
NEUROBRO_URL=https://app.neurobro.ai
NEUROBRO_STORAGE_STATE=./neurobro-session.json
POLL_INTERVAL_SECS=60
COOLDOWN_SECS=300
MAX_DEVIATION=0.004
# Lower timeframe (entry timing) date-range tab + higher timeframe (trend bias). Both
# screenshots are sent to Neurobro (HTF first, LTF second). Set HL_TIMEFRAME_HTF empty to
# disable multi-timeframe and send only the LTF image. HL tab VALUES are uppercase (the
# label is lowercase): 1D=1d/1min, 5D=5d/5min, 1M=1mo/30min, 3M, 6M, 12M=1y, 60M=5y.
HL_TIMEFRAME=1D
HL_TIMEFRAME_HTF=5D
# Volatility (ATR) hint injected into the prompt, fetched from the public info API.
HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
ATR_INTERVAL=5m
ATR_PERIOD=14
# Deterministic guardrails applied to every parsed setup before execution:
# reject below this reward:risk, or with a stop wider than this fraction of entry.
MIN_RISK_REWARD=1.5
MAX_STOP_LOSS_PCT=0.03
# Persistent Chrome profile dir (Cloudflare cf_clearance + Neurobro auth live here)
NEUROBRO_USER_DATA_DIR=./neurobro-profile
# Run headful by default (Cloudflare flags headless). Set true only under xvfb.
HEADLESS=false
# Use real installed Chrome instead of Playwright's bundled Chromium
BROWSER_CHANNEL=chrome
# Optional operator alerts when the Neurobro session dies (Cloudflare/login wall).
# Reuse the bot's Telegram token + your chat id. Empty → alerts only logged.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Neurobro quota guard. Each chart analysis = 1 "light" chat (~100/day on the plan).
# Hard daily cap (persisted, resets daily) + per-cycle cap to spread usage.
# dry-run/once count too; lower MAX_ANALYSES_PER_DAY if you also use Neurobro manually.
MAX_ANALYSES_PER_DAY=100
MAX_ANALYSES_PER_CYCLE=0
NEUROBRO_QUOTA_STATE=./neurobro-quota.json
# Home-run (Makefile tunnel target): VPS SSH host + bot Service ClusterIP. NOT committed
# with real values — keep them here in your local .env only. Fetch the ClusterIP with:
#   ssh $VPS_HOST "kubectl -n agentic-hyperliquid get svc bot -o jsonpath='{.spec.clusterIP}'"
VPS_HOST=root@your.vps.ip
BOT_CLUSTER_IP=10.43.x.x
